class Solution(object):
    def twoSum(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        dic={}
        for i in range(len(nums)):
            need= target-nums[i]
            if need in dic: 
                return [i,dic[need]]
            dic[nums[i]]=i
