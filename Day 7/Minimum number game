class Solution(object):
    def numberGame(self, nums):
        """
        :type nums: List[int]
        :rtype: List[int]
        """
        arr=[]
        nums.sort(reverse=True)
        while nums: 
            alice=nums.pop()
            bob=nums.pop()
            arr.append(bob)
            arr.append(alice) 
        return arr
