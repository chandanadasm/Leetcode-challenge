class Solution(object):
    def countMatches(self, items, ruleKey, ruleValue):
        """
        :type items: List[List[str]]
        :type ruleKey: str
        :type ruleValue: str
        :rtype: int
        """
        count=0
        if ruleKey=="type":
            index=0
        elif ruleKey=="color":
            index=1
        else:
            index=2
        for i in items:
            if i[index]==ruleValue:
                count+=1
        return count
